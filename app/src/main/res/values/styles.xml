<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AiImeMvp" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/keyboard_text</item>
    </style>

    <style name="KeyboardLetterButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:backgroundTint">@color/keyboard_key_background</item>
        <item name="android:textColor">@color/keyboard_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">18sp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="KeyboardActionButton">
        <item name="android:backgroundTint">@color/keyboard_action_background</item>
        <item name="android:textColor">@color/keyboard_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="CandidateButton">
        <item name="android:backgroundTint">@color/keyboard_candidate_background</item>
        <item name="android:textColor">@color/keyboard_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
    </style>
</resources>
